# URL RPC của mạng blockchain (Hardhat local hoặc testnet)
RPC_URL=http://127.0.0.1:8545

# Địa chỉ Smart Contract đã deploy (0x + 40 ký tự hex)
CONTRACT_ADDRESS=0x...

# URL backend API (không có dấu / ở cuối)
API_URL=http://localhost:8080

# JWT token của tài khoản ADMIN (lấy từ POST /api/auth/login)
ADMIN_TOKEN=eyJhbGciOiJIUzI1NiJ9...
